# ============================================
# COPY THIS FILE TO .env.local FOR LOCAL DEV
# ADD THESE AS ENVIRONMENT VARIABLES IN VERCEL
# ============================================

# 1. Vercel AI Gateway Key
#    Get from: https://vercel.com/ai-gateway
#    Used for: AI-powered rebalancing + stock research (Claude via gateway)
VERCEL_AI_GATEWAY_KEY=your_vercel_ai_gateway_key_here

# 2. NewsAPI Key (optional - app shows mock news without it)
#    Get from: https://newsapi.org (free tier)
#    Used for: Live financial news in the News tab
NEWSAPI_KEY=your_newsapi_key_here

# 3. Finnhub Key (optional - currently using Yahoo Finance by default)
#    Get from: https://finnhub.io (free tier)
#    Used for: Alternative stock data source
FINNHUB_KEY=your_finnhub_key_here
